<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <config>
    <!-- Set repositoryPath to a folder under the user's profile -->
    <add key="repositoryPath" value="packages" />
  </config>
</configuration>
