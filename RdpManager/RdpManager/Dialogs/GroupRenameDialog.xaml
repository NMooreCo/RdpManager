<UserControl x:Class="RdpManager.Dialogs.GroupRenameDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="400">
    <Border Background="{DynamicResource App.Background.Surface}"
            BorderBrush="{DynamicResource App.Border.Outline}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24">
        <StackPanel>
            <!-- Title -->
            <TextBlock x:Name="TitleText"
                       Text="Rename Group"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Text.Primary}"
                       Margin="0,0,0,20"/>

            <!-- Group Name -->
            <TextBox x:Name="GroupNameTextBox"
                     materialDesign:HintAssist.Hint="Group Name"
                     FontSize="13"
                     Margin="0,0,0,20"
                     Background="{DynamicResource App.Background.Elevated}"
                     Foreground="{DynamicResource App.Text.Primary}"
                     BorderBrush="{DynamicResource App.Border.Outline}"
                     Padding="12,8"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}">
                    <Button.CommandParameter>
                        <system:Boolean xmlns:system="clr-namespace:System;assembly=mscorlib">False</system:Boolean>
                    </Button.CommandParameter>
                </Button>
                <Button Content="Save"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
