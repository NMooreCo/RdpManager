<UserControl x:Class="RdpManager.Dialogs.CredentialsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="400">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Settings"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource App.Text.Primary}"
                   Margin="0,0,0,24"/>

        <!-- Username Field -->
        <TextBox Grid.Row="1"
                 x:Name="UsernameTextBox"
                 materialDesign:HintAssist.Hint="Username"
                 materialDesign:HintAssist.HelperText="Enter your domain\username"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <!-- Password Field -->
        <PasswordBox Grid.Row="2"
                     x:Name="PasswordBox"
                     materialDesign:HintAssist.Hint="Password"
                     materialDesign:HintAssist.HelperText="Enter your password"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                     Margin="0,0,0,16"/>

        <!-- Server Endpoint Field -->
        <TextBox Grid.Row="3"
                 x:Name="ServerEndpointTextBox"
                 materialDesign:HintAssist.Hint="Server Endpoint URL"
                 materialDesign:HintAssist.HelperText="API endpoint used by the Servers tab"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <!-- RDP Mode Preference -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <CheckBox x:Name="UseEmbeddedRdpCheckBox"
                      Content="Use embedded RDP sessions (recommended)"
                      Margin="0,0,0,4"/>
            <TextBlock Text="Opens RDP connections in tabs within the application instead of external windows"
                       TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource App.Text.Secondary}"
                       Margin="24,0,0,0"/>
        </StackPanel>

        <!-- Info Card -->
        <materialDesign:Card Grid.Row="5" Padding="16" Margin="0,0,0,24"
                             Background="{DynamicResource App.Background.Elevated}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Information" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Credentials are stored securely in Windows Credential Manager"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="CANCEL"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="False"
                    Margin="0,0,8,0"/>
            <Button Content="SAVE"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsDefault="True"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>