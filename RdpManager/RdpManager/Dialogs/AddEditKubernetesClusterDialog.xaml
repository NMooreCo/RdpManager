<UserControl x:Class="RdpManager.Dialogs.AddEditKubernetesClusterDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="550">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" x:Name="TitleText" Text="Add Kubernetes Cluster"
                   FontSize="24" FontWeight="Regular"
                   Margin="0,0,0,24"/>

        <!-- Display Name -->
        <TextBox Grid.Row="1"
                 x:Name="DisplayNameTextBox"
                 materialDesign:HintAssist.Hint="Display Name"
                 materialDesign:HintAssist.HelperText="A friendly name for this cluster (e.g., GKE Dev - Dispensing)"
                 materialDesign:TextFieldAssist.LeadingIcon="Label"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <!-- GCP Project ID -->
        <TextBox Grid.Row="2"
                 x:Name="ProjectIdTextBox"
                 materialDesign:HintAssist.Hint="GCP Project ID"
                 materialDesign:HintAssist.HelperText="e.g., pharmacy-dev-dispensing"
                 materialDesign:TextFieldAssist.LeadingIcon="GoogleCloud"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <!-- Cluster Name -->
        <TextBox Grid.Row="3"
                 x:Name="ClusterNameTextBox"
                 materialDesign:HintAssist.Hint="Cluster Name"
                 materialDesign:HintAssist.HelperText="e.g., gke-dispensing-dev"
                 materialDesign:TextFieldAssist.LeadingIcon="Kubernetes"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <!-- Region -->
        <TextBox Grid.Row="4"
                 x:Name="RegionTextBox"
                 materialDesign:HintAssist.Hint="Region"
                 materialDesign:HintAssist.HelperText="e.g., us-east4"
                 materialDesign:TextFieldAssist.LeadingIcon="MapMarker"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <!-- Default Namespace -->
        <TextBox Grid.Row="5"
                 x:Name="DefaultNamespaceTextBox"
                 materialDesign:HintAssist.Hint="Default Namespace"
                 materialDesign:HintAssist.HelperText="e.g., hal-dev"
                 materialDesign:TextFieldAssist.LeadingIcon="FolderOutline"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16"/>

        <!-- Proxy Settings Expander -->
        <Expander Grid.Row="6" Header="Proxy Settings" Margin="0,0,0,16" IsExpanded="True">
            <Grid Margin="24,16,24,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0"
                         x:Name="ProxyAddressTextBox"
                         materialDesign:HintAssist.Hint="Proxy Address (after auth)"
                         materialDesign:HintAssist.HelperText="e.g., 10.114.2.219:443 - Set as HTTPS_PROXY after gcloud auth"
                         materialDesign:TextFieldAssist.LeadingIcon="Shield"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>

                <CheckBox Grid.Row="1"
                          x:Name="ClearProxyBeforeAuthCheckBox"
                          Content="Clear proxy before authentication"
                          IsChecked="True"
                          Style="{StaticResource MaterialDesignCheckBox}"/>
            </Grid>
        </Expander>

        <!-- Test Connection Area -->
        <Grid Grid.Row="7" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    x:Name="TestConnectionButton"
                    Content="TEST CONNECTION"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="TestConnectionButton_Click"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,8"/>

            <TextBox Grid.Row="1"
                     x:Name="TestOutputTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     MaxHeight="120"
                     VerticalScrollBarVisibility="Auto"
                     Visibility="Collapsed"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     FontFamily="Consolas"
                     FontSize="11"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="CANCEL"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Null}"
                    Margin="0,0,8,0"/>
            <Button Content="SAVE"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    IsDefault="True"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
