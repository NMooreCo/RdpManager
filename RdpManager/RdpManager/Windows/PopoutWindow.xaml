<windows:BorderlessWindowBase x:Class="RdpManager.Windows.PopoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:windows="clr-namespace:RdpManager.Windows"
        xmlns:models="clr-namespace:RdpManager.Models"
        Title="RDP Session"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        WindowState="Maximized"
        FontFamily="Segoe UI, -apple-system, BlinkMacSystemFont, sans-serif">

    <!-- WindowChrome for native resize/drag behavior -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      CornerRadius="0"
                      GlassFrameThickness="1"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Converter for null/empty string to visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- Header Icon Button (for dark header background with white icons) -->
        <Style x:Key="HeaderIconButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4DFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Button (Full-height, modern style) -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4DFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Window Button (Full-height with red hover) -->
        <Style x:Key="CloseWindowButton" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C50F1F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Success Button Style -->
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource App.Semantic.Success}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowBorder"
            CornerRadius="0"
            Background="{DynamicResource App.Background.Window}"
            BorderBrush="{DynamicResource App.Border.Divider}"
            BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Professional Header (Draggable) -->
            <Border Grid.Row="0" Background="{DynamicResource App.Header.Background}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Status icon -->
                        <ColumnDefinition Width="Auto"/> <!-- FriendlyName -->
                        <ColumnDefinition Width="Auto"/> <!-- Group -->
                        <ColumnDefinition Width="Auto"/> <!-- ServerAddress -->
                        <ColumnDefinition Width="Auto"/> <!-- Connect button -->
                        <ColumnDefinition Width="*"/>    <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/> <!-- Actions + Window controls -->
                    </Grid.ColumnDefinitions>

                    <!-- Status Icon -->
                    <Ellipse Grid.Column="0" Width="8" Height="8" Margin="12,0,8,0"
                             VerticalAlignment="Center"
                             Fill="{Binding Session.StatusColor, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <!-- FriendlyName (Bold) -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding Session.FriendlyName, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource App.Header.Foreground}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Group (in brackets, only if not empty) -->
                    <TextBlock Grid.Column="2"
                               x:Name="GroupText"
                               Text="{Binding Session.Group, RelativeSource={RelativeSource AncestorType=Window}, StringFormat='[{0}]'}"
                               FontSize="14"
                               Foreground="{DynamicResource App.Header.Foreground}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Session.Group, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Session.Group, RelativeSource={RelativeSource AncestorType=Window}}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ServerAddress (in parentheses) -->
                    <TextBlock Grid.Column="3"
                               Text="{Binding Session.ServerAddress, RelativeSource={RelativeSource AncestorType=Window}, StringFormat='({0})'}"
                               FontSize="14"
                               Foreground="{DynamicResource App.Header.Foreground}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>

                    <!-- Connect Button (visible when disconnected/failed) -->
                    <Button Grid.Column="4" x:Name="ReconnectButton"
                            Margin="12,0,0,0"
                            Padding="8,4"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="ReconnectButton_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SuccessButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Session.ConnectionState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Disconnected">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Session.ConnectionState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Failed">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M13,19H14A1,1 0 0,1 15,20H22V22H15A1,1 0 0,1 14,23H10A1,1 0 0,1 9,22H2V20H9A1,1 0 0,1 10,19H11V17H7A1,1 0 0,1 6,16V12A1,1 0 0,1 7,11H17A1,1 0 0,1 18,12V16A1,1 0 0,1 17,17H13V19M7,2H17A2,2 0 0,1 19,4V10H18V4H6V10H5V4A2,2 0 0,1 7,2Z"
                                  Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="Connect" FontSize="12" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <!-- Right: Actions + Window Controls -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Stretch" Margin="0,0,0,0">
                        <!-- Pop-in Button -->
                        <Button x:Name="PopInButton"
                                Style="{StaticResource HeaderIconButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="PopInButton_Click"
                                ToolTip="Pop session back into main window"
                                Margin="0,0,8,0">
                            <Path Data="M10,14H19V5H10M5,14H14V20H5M10,3V6H19V20H14V23H5A2,2 0 0,1 3,21V6H10V3M12,16L16,12L12,8V11H9V13H12V16Z"
                                  Fill="{DynamicResource App.Header.Foreground}" Width="18" Height="18" Stretch="Uniform"/>
                        </Button>

                        <!-- Window Controls (Full-height) -->
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource WindowControlButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="MinimizeButton_Click"
                                ToolTip="Minimize">
                            <Path Data="M20,14H4V10H20" Fill="{DynamicResource App.Header.Foreground}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="MaximizeButton"
                                Style="{StaticResource WindowControlButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="MaximizeButton_Click"
                                ToolTip="Maximize">
                            <Path x:Name="MaximizeIcon" Data="M4,4H20V20H4V4M6,8V18H18V8H6Z" Fill="{DynamicResource App.Header.Foreground}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="CloseButton"
                                Style="{StaticResource CloseWindowButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="CloseButton_Click"
                                ToolTip="Close">
                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="{DynamicResource App.Header.Foreground}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RDP Content Area -->
            <Grid Grid.Row="1" Background="Black" ClipToBounds="True" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <ContentControl x:Name="RdpContentHost"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Margin="0"
                                Padding="0"
                                ClipToBounds="True"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True"/>
            </Grid>
        </Grid>
    </Border>
</windows:BorderlessWindowBase>
