<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Material Design 5 Theme Configuration -->
    <ResourceDictionary.MergedDictionaries>
        <!-- BundledTheme provides base theming and controls -->
        <materialDesign:BundledTheme BaseTheme="Light"
                                      PrimaryColor="Blue"
                                      SecondaryColor="Orange" />

        <!-- MaterialDesign3.Defaults provides all control styles -->
        <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ====================================================================
         CUSTOM APPLICATION COLOR SYSTEM
         Professional Blue + Complementary Orange | Navy-tinted Dark Mode
         ================================================================= -->

    <!-- LIGHT MODE COLORS -->
    <!-- ================= -->

    <!-- Backgrounds (Light) -->
    <SolidColorBrush x:Key="App.Background.Window.Light" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="App.Background.Surface.Light" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="App.Background.Elevated.Light" Color="#F5F5F5"/>

    <!-- Primary - Vibrant Professional Blue (Light) -->
    <SolidColorBrush x:Key="App.Primary.Light" Color="#1976D2"/>
    <SolidColorBrush x:Key="App.Primary.Lighter.Light" Color="#42A5F5"/>
    <SolidColorBrush x:Key="App.Primary.Darker.Light" Color="#1565C0"/>
    <SolidColorBrush x:Key="App.Primary.Foreground.Light" Color="#FFFFFF"/>

    <!-- Secondary - Complementary Orange (Light) -->
    <SolidColorBrush x:Key="App.Secondary.Light" Color="#FF6F00"/>
    <SolidColorBrush x:Key="App.Secondary.Lighter.Light" Color="#FFA040"/>
    <SolidColorBrush x:Key="App.Secondary.Darker.Light" Color="#C43E00"/>
    <SolidColorBrush x:Key="App.Secondary.Foreground.Light" Color="#FFFFFF"/>

    <!-- Text (Light) -->
    <SolidColorBrush x:Key="App.Text.Primary.Light" Color="#212121"/>
    <SolidColorBrush x:Key="App.Text.Secondary.Light" Color="#757575"/>
    <SolidColorBrush x:Key="App.Text.Disabled.Light" Color="#BDBDBD"/>

    <!-- Borders & Dividers (Light) -->
    <SolidColorBrush x:Key="App.Border.Divider.Light" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="App.Border.Outline.Light" Color="#BDBDBD"/>

    <!-- Semantic Colors (Light) -->
    <SolidColorBrush x:Key="App.Semantic.Success.Light" Color="#4CAF50"/>
    <SolidColorBrush x:Key="App.Semantic.Warning.Light" Color="#FF9800"/>
    <SolidColorBrush x:Key="App.Semantic.Error.Light" Color="#F44336"/>
    <SolidColorBrush x:Key="App.Semantic.Info.Light" Color="#2196F3"/>

    <!-- Interactive States (Light) -->
    <SolidColorBrush x:Key="App.Hover.Light" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="App.Selection.Light" Color="#F0F0F0"/>


    <!-- DARK MODE COLORS (Navy-tinted) -->
    <!-- =============================== -->

    <!-- Backgrounds (Dark Navy) -->
    <SolidColorBrush x:Key="App.Background.Window.Dark" Color="#0A1929"/>
    <SolidColorBrush x:Key="App.Background.Surface.Dark" Color="#1E2A3A"/>
    <SolidColorBrush x:Key="App.Background.Elevated.Dark" Color="#2D3E50"/>

    <!-- Primary - Lighter Blue for Dark Mode -->
    <SolidColorBrush x:Key="App.Primary.Dark" Color="#64B5F6"/>
    <SolidColorBrush x:Key="App.Primary.Lighter.Dark" Color="#9BE7FF"/>
    <SolidColorBrush x:Key="App.Primary.Darker.Dark" Color="#2286C3"/>
    <SolidColorBrush x:Key="App.Primary.Foreground.Dark" Color="#000000"/>

    <!-- Secondary - Lighter Orange for Dark Mode -->
    <SolidColorBrush x:Key="App.Secondary.Dark" Color="#FFB74D"/>
    <SolidColorBrush x:Key="App.Secondary.Lighter.Dark" Color="#FFE97D"/>
    <SolidColorBrush x:Key="App.Secondary.Darker.Dark" Color="#C88719"/>
    <SolidColorBrush x:Key="App.Secondary.Foreground.Dark" Color="#000000"/>

    <!-- Text (Dark) -->
    <SolidColorBrush x:Key="App.Text.Primary.Dark" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="App.Text.Secondary.Dark" Color="#B0BEC5"/>
    <SolidColorBrush x:Key="App.Text.Disabled.Dark" Color="#607D8B"/>

    <!-- Borders & Dividers (Dark Navy) -->
    <SolidColorBrush x:Key="App.Border.Divider.Dark" Color="#37474F"/>
    <SolidColorBrush x:Key="App.Border.Outline.Dark" Color="#546E7A"/>

    <!-- Semantic Colors (Dark - Lighter versions) -->
    <SolidColorBrush x:Key="App.Semantic.Success.Dark" Color="#81C784"/>
    <SolidColorBrush x:Key="App.Semantic.Warning.Dark" Color="#FFB74D"/>
    <SolidColorBrush x:Key="App.Semantic.Error.Dark" Color="#E57373"/>
    <SolidColorBrush x:Key="App.Semantic.Info.Dark" Color="#64B5F6"/>

    <!-- Interactive States (Dark) -->
    <SolidColorBrush x:Key="App.Hover.Dark" Color="#2D3E50"/>
    <SolidColorBrush x:Key="App.Selection.Dark" Color="#1E3A5F"/>


    <!-- ACTIVE THEME COLORS (Start with Light mode, will be updated by theme toggle) -->
    <!-- ============================================================================ -->

    <!-- Backgrounds (Default to Light) -->
    <SolidColorBrush x:Key="App.Background.Window" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="App.Background.Surface" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="App.Background.Elevated" Color="#F5F5F5"/>

    <!-- Header Background (Gray in light, blended navy in dark) -->
    <SolidColorBrush x:Key="App.Header.Background.Light" Color="#37474F"/>
    <SolidColorBrush x:Key="App.Header.Background.Dark" Color="#2D3E50"/>
    <SolidColorBrush x:Key="App.Header.Background" Color="#37474F"/>
    <SolidColorBrush x:Key="App.Header.Foreground.Light" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="App.Header.Foreground.Dark" Color="#B0BEC5"/>
    <SolidColorBrush x:Key="App.Header.Foreground" Color="#FFFFFF"/>

    <!-- Primary Colors (Default to Light - Vibrant Blue) -->
    <SolidColorBrush x:Key="App.Primary" Color="#1976D2"/>
    <SolidColorBrush x:Key="App.Primary.Foreground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="App.Primary.Lighter" Color="#42A5F5"/>
    <SolidColorBrush x:Key="App.Primary.Darker" Color="#1565C0"/>

    <!-- Secondary Colors (Default to Light) -->
    <SolidColorBrush x:Key="App.Secondary" Color="#FF6F00"/>
    <SolidColorBrush x:Key="App.Secondary.Foreground" Color="#FFFFFF"/>

    <!-- Text (Default to Light) -->
    <SolidColorBrush x:Key="App.Text.Primary" Color="#212121"/>
    <SolidColorBrush x:Key="App.Text.Secondary" Color="#757575"/>

    <!-- Borders (Default to Light) -->
    <SolidColorBrush x:Key="App.Border.Divider" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="App.Border.Outline" Color="#BDBDBD"/>

    <!-- Interactive States (Default to Light) -->
    <SolidColorBrush x:Key="App.Hover" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="App.Selection" Color="#F0F0F0"/>

    <!-- Semantic Colors (Status indicators - always visible regardless of theme) -->
    <SolidColorBrush x:Key="App.Semantic.Success" Color="#4CAF50"/>
    <SolidColorBrush x:Key="App.Semantic.Warning" Color="#FF9800"/>
    <SolidColorBrush x:Key="App.Semantic.Error" Color="#F44336"/>
    <SolidColorBrush x:Key="App.Semantic.Info" Color="#2196F3"/>

    <!-- Legacy Status Brushes (for backwards compatibility) -->
    <SolidColorBrush x:Key="StatusConnectedBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="StatusConnectingBrush" Color="#FF9800"/>
    <SolidColorBrush x:Key="StatusDisconnectedBrush" Color="#9E9E9E"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="#F44336"/>

</ResourceDictionary>
