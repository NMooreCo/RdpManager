<UserControl x:Class="RdpManager.Views.FileExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:RdpManager.Views"
             xmlns:models="clr-namespace:RdpManager.Models">

    <UserControl.Resources>
        <!-- Tab Style for Explorer Tabs -->
        <Style x:Key="ExplorerTabStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource App.Background.Secondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Border.Divider}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="MaxWidth" Value="250"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource App.Background.Hover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Active Tab Style -->
        <Style x:Key="ActiveExplorerTabStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource App.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Border.Divider}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="MaxWidth" Value="250"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource App.Background.Primary}">
        <Grid.RowDefinitions>
            <!-- Tab bar -->
            <RowDefinition Height="Auto"/>
            <!-- Navigation bar -->
            <RowDefinition Height="Auto"/>
            <!-- Content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource App.Background.Secondary}"
                BorderBrush="{DynamicResource App.Border.Divider}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Background="Transparent">
                <StackPanel x:Name="TabPanel"
                            Orientation="Horizontal"
                            Background="Transparent"/>
            </ScrollViewer>
        </Border>

        <!-- Navigation Bar -->
        <Border Grid.Row="1"
                x:Name="NavigationBar"
                Background="{DynamicResource App.Background.Primary}"
                BorderBrush="{DynamicResource App.Border.Divider}"
                BorderThickness="0,0,0,1"
                Padding="8,6"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Back -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Forward -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Up -->
                    <ColumnDefinition Width="*"/>
                    <!-- Path -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Refresh -->
                </Grid.ColumnDefinitions>

                <!-- Back Button -->
                <Button x:Name="BackButton"
                        Grid.Column="0"
                        Width="32"
                        Height="32"
                        Margin="0,0,4,0"
                        ToolTip="Back"
                        IsEnabled="False"
                        Style="{DynamicResource MaterialDesignFlatButton}">
                    <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"
                          Fill="{DynamicResource App.Text.Secondary}"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"/>
                </Button>

                <!-- Forward Button -->
                <Button x:Name="ForwardButton"
                        Grid.Column="1"
                        Width="32"
                        Height="32"
                        Margin="0,0,4,0"
                        ToolTip="Forward"
                        IsEnabled="False"
                        Style="{DynamicResource MaterialDesignFlatButton}">
                    <Path Data="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z"
                          Fill="{DynamicResource App.Text.Secondary}"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"/>
                </Button>

                <!-- Up Button -->
                <Button x:Name="UpButton"
                        Grid.Column="2"
                        Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        ToolTip="Up to parent folder"
                        Style="{DynamicResource MaterialDesignFlatButton}">
                    <Path Data="M7.41,15.41L12,10.83L16.59,15.41L18,14L12,8L6,14L7.41,15.41Z"
                          Fill="{DynamicResource App.Text.Secondary}"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"/>
                </Button>

                <!-- Path TextBox -->
                <TextBox x:Name="PathTextBox"
                         Grid.Column="3"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         Padding="8,6"
                         FontSize="13"
                         IsReadOnly="False"
                         Background="{DynamicResource App.Background.Secondary}"
                         Foreground="{DynamicResource App.Text.Primary}"
                         BorderBrush="{DynamicResource App.Border.Divider}"
                         BorderThickness="1"/>

                <!-- Refresh Button -->
                <Button x:Name="RefreshButton"
                        Grid.Column="4"
                        Width="32"
                        Height="32"
                        ToolTip="Refresh"
                        Style="{DynamicResource MaterialDesignFlatButton}">
                    <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                          Fill="{DynamicResource App.Text.Secondary}"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Border Grid.Row="2"
                Background="{DynamicResource App.Background.Primary}"
                ClipToBounds="True">
            <Grid>
                <!-- Content host for FileExplorerSessionControl -->
                <ContentControl x:Name="ExplorerContentHost"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Margin="0"
                                Padding="0"
                                ClipToBounds="True"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True"/>

                <!-- Empty State -->
                <StackPanel x:Name="EmptyStatePanel"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Visible">
                    <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                          Fill="{DynamicResource App.Border.Divider}"
                          Width="80"
                          Height="80"
                          Stretch="Uniform"
                          Margin="0,0,0,24"/>
                    <TextBlock Text="No Folder Opened"
                               FontSize="18"
                               Foreground="{DynamicResource App.Text.Primary}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Right-click a computer in the Computers view&#x0a;and select 'Explore Files in App' to open a folder"
                               FontSize="13"
                               Foreground="{DynamicResource App.Text.Secondary}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               MaxWidth="400"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
