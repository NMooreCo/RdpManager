<UserControl x:Class="RdpManager.Views.RecentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:RdpManager.Models"
             xmlns:converters="clr-namespace:RdpManager.Converters">

    <UserControl.Resources>
        <converters:NullToFontWeightConverter x:Key="NullToFontWeightConverter" NullFontWeight="SemiBold" NotNullFontWeight="Normal" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource Toolbar}">
            <Button x:Name="ConnectButton" Click="ConnectButton_Click"
                    Style="{StaticResource PrimaryButton}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M13,19H14A1,1 0 0,1 15,20H22V22H15A1,1 0 0,1 14,23H10A1,1 0 0,1 9,22H2V20H9A1,1 0 0,1 10,19H11V17H7A1,1 0 0,1 6,16V12A1,1 0 0,1 7,11H17A1,1 0 0,1 18,12V16A1,1 0 0,1 17,17H13V19M7,2H17A2,2 0 0,1 19,4V10H18V4H6V10H5V4A2,2 0 0,1 7,2Z"
                          Fill="{DynamicResource App.Primary.Foreground}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                    <TextBlock Text="Connect"/>
                </StackPanel>
            </Button>
        </Border>

        <!-- Content -->
        <TreeView x:Name="RecentTreeView" Grid.Row="1"
                  ItemsSource="{Binding}"
                  BorderThickness="0"
                  Background="Transparent"
                  Padding="12"
                  MouseDoubleClick="RecentTreeView_MouseDoubleClick">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TreeViewItem">
                                <Grid Background="Transparent">
                                    <ContentPresenter x:Name="PART_Header" ContentSource="Header"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type models:TreeNode}" ItemsSource="{Binding Children}">
                    <Border Padding="8,6" CornerRadius="4" Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <!-- TimeAgo (gray) -->
                            <TextBlock Text="{Binding TimeAgo}" FontSize="13"
                                       Foreground="{DynamicResource App.Text.Secondary}"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="•" FontSize="13"
                                       Foreground="{DynamicResource App.Text.Secondary}"
                                       Margin="0,0,6,0"/>
                            <!-- FriendlyName (bold) -->
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Text.Primary}"
                                       Margin="0,0,6,0"/>
                            <!-- Group [if present] -->
                            <TextBlock Text="{Binding ComputerEntry.Group, StringFormat='[{0}]'}" FontSize="13"
                                       Foreground="{DynamicResource App.Text.Primary}"
                                       Margin="0,0,6,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ComputerEntry.Group}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ComputerEntry.Group}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- ServerAddress (gray, in parentheses) -->
                            <TextBlock FontSize="13" Foreground="{DynamicResource App.Text.Secondary}">
                                <Run Text="("/><Run Text="{Binding ComputerEntry.MachineName, Mode=OneWay}"/><Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Selection}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Hover}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </HierarchicalDataTemplate>
            </TreeView.Resources>
        </TreeView>
    </Grid>
</UserControl>
