<UserControl x:Class="RdpManager.Views.ComputersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:RdpManager.Models"
             xmlns:converters="clr-namespace:RdpManager.Converters">

    <UserControl.Resources>
        <converters:NullToFontWeightConverter x:Key="NullToFontWeightConverter" NullFontWeight="SemiBold" NotNullFontWeight="Normal" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Expand/Collapse Toggle Button Style -->
        <Style x:Key="ExpandCollapseToggleStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" Width="16" Height="16">
                            <Path x:Name="ExpandPath"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                  Fill="{DynamicResource App.Text.Secondary}"
                                  Width="10"
                                  Height="10"
                                  Stretch="Uniform"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ExpandPath" Property="Data" Value="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ExpandPath" Property="Fill" Value="{DynamicResource App.Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" CornerRadius="8,8,0,0" Style="{StaticResource Toolbar}">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddButton" Click="AddButton_Click"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                              Fill="{DynamicResource App.Text.Primary}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="Add" FontSize="13" FontWeight="Medium"/>
                    </StackPanel>
                </Button>

                <Button x:Name="EditButton" Content="Edit" Click="EditButton_Click"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>

                <Button x:Name="RemoveButton" Content="Remove" Click="RemoveButton_Click"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,16,0"/>

                <Rectangle Width="1" Height="24" Fill="{DynamicResource App.Border.Divider}" Margin="0,0,16,0"/>

                <Button x:Name="ConnectButton" Click="ConnectButton_Click"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M13,19H14A1,1 0 0,1 15,20H22V22H15A1,1 0 0,1 14,23H10A1,1 0 0,1 9,22H2V20H9A1,1 0 0,1 10,19H11V17H7A1,1 0 0,1 6,16V12A1,1 0 0,1 7,11H17A1,1 0 0,1 18,12V16A1,1 0 0,1 17,17H13V19M7,2H17A2,2 0 0,1 19,4V10H18V4H6V10H5V4A2,2 0 0,1 7,2Z"
                              Fill="{DynamicResource App.Primary.Foreground}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="Connect"/>
                    </StackPanel>
                </Button>

                <Rectangle Width="1" Height="24" Fill="{DynamicResource App.Border.Divider}" Margin="0,0,16,0"/>

                <Button x:Name="ImportButton" Content="Import" Click="ImportButton_Click"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>

                <Button x:Name="ExportButton" Content="Export" Click="ExportButton_Click"
                        Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
        </Border>

        <!-- Content - TreeView -->
        <Border BorderThickness="0" CornerRadius="0,0,8,8" Grid.Row="1">
            <TreeView x:Name="ComputersTreeView"
                  ItemsSource="{Binding RootNodes}"
                  BorderThickness="0"
                  Background="Transparent"
                  Padding="12"
                  SelectedItemChanged="ComputersTreeView_SelectedItemChanged"
                  MouseDoubleClick="ComputersTreeView_MouseDoubleClick">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="AllowDrop" Value="True"/>
                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TreeViewItem_PreviewMouseLeftButtonDown"/>
                    <EventSetter Event="PreviewMouseMove" Handler="TreeViewItem_PreviewMouseMove"/>
                    <EventSetter Event="DragOver" Handler="TreeViewItem_DragOver"/>
                    <EventSetter Event="Drop" Handler="TreeViewItem_Drop"/>
                    <EventSetter Event="DragLeave" Handler="TreeViewItem_DragLeave"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TreeViewItem">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Expand/Collapse Toggle -->
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  Style="{StaticResource ExpandCollapseToggleStyle}"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"
                                                  Margin="0,0,4,0"/>

                                    <!-- Content -->
                                    <ContentPresenter x:Name="PART_Header"
                                                      Grid.Column="1"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>

                                    <!-- Children Items -->
                                    <ItemsPresenter x:Name="ItemsHost"
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="10,0,0,0"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsExpanded" Value="false">
                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                    <Trigger Property="HasItems" Value="false">
                                        <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.Resources>
                <!-- Computer Context Menu (for leaf nodes) -->
                <ContextMenu x:Key="ComputerContextMenu" Style="{StaticResource CompactContextMenu}">
                    <MenuItem Header="Connect" Click="ContextMenu_Connect" Style="{StaticResource CompactMenuItem}">
                        <MenuItem.Icon>
                            <Path Data="M13,19H14A1,1 0 0,1 15,20H22V22H15A1,1 0 0,1 14,23H10A1,1 0 0,1 9,22H2V20H9A1,1 0 0,1 10,19H11V17H7A1,1 0 0,1 6,16V12A1,1 0 0,1 7,11H17A1,1 0 0,1 18,12V16A1,1 0 0,1 17,17H13V19M7,2H17A2,2 0 0,1 19,4V10H18V4H6V10H5V4A2,2 0 0,1 7,2Z"
                                  Fill="{DynamicResource App.Primary}" Width="12" Height="12" Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Copy Machine Name" Click="ContextMenu_CopyMachineName" Style="{StaticResource CompactMenuItem}">
                        <MenuItem.Icon>
                            <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"
                                  Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Open File Explorer" Click="ContextMenu_OpenFileExplorer" Style="{StaticResource CompactMenuItem}">
                        <MenuItem.Icon>
                            <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                                  Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Explore Files in App" Click="ContextMenu_ExploreInApp" Style="{StaticResource CompactMenuItem}">
                        <MenuItem.Icon>
                            <Path Data="M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z"
                                  Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Edit" Click="ContextMenu_Edit" Style="{StaticResource CompactMenuItem}">
                        <MenuItem.Icon>
                            <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                  Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Duplicate" Click="ContextMenu_Duplicate" Style="{StaticResource CompactMenuItem}">
                        <MenuItem.Icon>
                            <Path Data="M11,17H4A2,2 0 0,1 2,15V3A2,2 0 0,1 4,1H16V3H4V15H11V13L15,16L11,19V17M19,21V7H8V13H6V7A2,2 0 0,1 8,5H19A2,2 0 0,1 21,7V21A2,2 0 0,1 19,23H8A2,2 0 0,1 6,21V19H8V21H19Z"
                                  Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Remove" Click="ContextMenu_Remove" Style="{StaticResource CompactMenuItem}">
                        <MenuItem.Icon>
                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                  Fill="#F44336" Width="12" Height="12" Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>

                <!-- Group Context Menu (for non-leaf nodes) -->
                <ContextMenu x:Key="GroupContextMenu" Style="{StaticResource CompactContextMenu}">
                    <MenuItem Header="Connect All" Click="ContextMenu_ConnectAll" Style="{StaticResource CompactMenuItem}" x:Name="ConnectAllMenuItem">
                        <MenuItem.Icon>
                            <Path Data="M13,19H14A1,1 0 0,1 15,20H22V22H15A1,1 0 0,1 14,23H10A1,1 0 0,1 9,22H2V20H9A1,1 0 0,1 10,19H11V17H7A1,1 0 0,1 6,16V12A1,1 0 0,1 7,11H17A1,1 0 0,1 18,12V16A1,1 0 0,1 17,17H13V19M7,2H17A2,2 0 0,1 19,4V10H18V4H6V10H5V4A2,2 0 0,1 7,2Z"
                                  Fill="{DynamicResource App.Primary}" Width="12" Height="12" Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Rename Group" Click="ContextMenu_RenameGroup" Style="{StaticResource CompactMenuItem}">
                        <MenuItem.Icon>
                            <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                  Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>

                <HierarchicalDataTemplate DataType="{x:Type models:TreeNode}" ItemsSource="{Binding Children}">
                    <Border Padding="8,6" CornerRadius="4" Margin="0,1" ContextMenuOpening="Border_ContextMenuOpening">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon and Text -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Path x:Name="ItemIcon"
                                      Data="M4,6H20V16H4M20,18A2,2 0 0,0 22,16V6C22,4.89 21.1,4 20,4H4C2.89,4 2,4.89 2,6V16A2,2 0 0,0 4,18H0V20H24V18H20Z"
                                      Fill="{DynamicResource App.Text.Secondary}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="{Binding ComputerEntry, Converter={StaticResource NullToFontWeightConverter}}"
                                           FontSize="13" Foreground="{DynamicResource App.Text.Primary}"/>
                                <TextBlock Text="{Binding ComputerEntry.MachineName}"
                                           Margin="8,0,0,0"
                                           Foreground="{DynamicResource App.Text.Secondary}"
                                           FontSize="12"/>
                            </StackPanel>

                            <!-- Favorite Button -->
                            <Button Grid.Column="1" Width="24" Height="24" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    Tag="{Binding}"
                                    Click="FavoriteButton_Click"
                                    Visibility="{Binding IsLeaf, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Path x:Name="FavoriteIcon" Width="14" Height="14" Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="M12,15.39L8.24,17.66L9.23,13.38L5.91,10.5L10.29,10.13L12,6.09L13.71,10.13L18.09,10.5L14.77,13.38L15.76,17.66M22,9.24L14.81,8.63L12,2L9.19,8.63L2,9.24L7.45,13.97L5.82,21L12,17.27L18.18,21L16.54,13.97L22,9.24Z"/>
                                            <Setter Property="Fill" Value="#9CA3AF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                    <Setter Property="Data" Value="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"/>
                                                    <Setter Property="Fill" Value="#FFB800"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>
                        </Grid>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="ContextMenu" Value="{StaticResource ComputerContextMenu}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLeaf}" Value="False">
                                        <Setter Property="ContextMenu" Value="{StaticResource GroupContextMenu}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Selection}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Hover}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <HierarchicalDataTemplate.Triggers>
                        <DataTrigger Binding="{Binding ComputerEntry}" Value="{x:Null}">
                            <Setter TargetName="ItemIcon" Property="Data" Value="M3,3H21V7H3V3M4,8H20V21H4V8M9.5,11A0.5,0.5 0 0,0 9,11.5V13H15V11.5A0.5,0.5 0 0,0 14.5,11H9.5Z"/>
                            <Setter TargetName="ItemIcon" Property="Fill" Value="#3B82F6"/>
                        </DataTrigger>
                    </HierarchicalDataTemplate.Triggers>
                </HierarchicalDataTemplate>
            </TreeView.Resources>
        </TreeView>
        </Border>
    </Grid>
</UserControl>
