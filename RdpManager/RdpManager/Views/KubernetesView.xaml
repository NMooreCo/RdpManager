<UserControl x:Class="RdpManager.Views.KubernetesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource App.Background.Window}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Expand/Collapse Toggle (matches ComputersView) -->
        <Style x:Key="K8sExpandCollapseToggle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" Width="16" Height="16">
                            <Path x:Name="ExpandPath"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                  Fill="{DynamicResource App.Text.Secondary}"
                                  Width="10" Height="10" Stretch="Uniform"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ExpandPath" Property="Data" Value="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ExpandPath" Property="Fill" Value="{DynamicResource App.Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeViewItem with full custom template (matches ComputersView selection/hover) -->
        <Style x:Key="K8sTreeViewItem" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Text.Primary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ToggleButton x:Name="Expander"
                                          Grid.Column="0"
                                          Style="{StaticResource K8sExpandCollapseToggle}"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Margin="0,0,4,0"/>

                            <Border x:Name="ContentBorder" Grid.Column="1"
                                    Background="Transparent" CornerRadius="4"
                                    Padding="8,4" Margin="0,1">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </Border>

                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1" Grid.Column="1"
                                            Margin="10,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="false">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource App.Selection}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource App.Hover}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid column header (keyed, explicitly set on DataGrid) -->
        <Style x:Key="K8sColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource App.Background.Elevated}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Text.Secondary}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Border.Divider}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <!-- DataGrid row (keyed) -->
        <Style x:Key="K8sRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource App.Background.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Text.Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource App.Selection}"/>
                    <Setter Property="Foreground" Value="{DynamicResource App.Text.Primary}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource App.Hover}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid cell (keyed) - TextElement.Foreground forces text color past DataGrid's internal overrides -->
        <Style x:Key="K8sCell" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource App.Text.Primary}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                TextElement.Foreground="{DynamicResource App.Text.Primary}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid style (explicitly wires sub-styles) -->
        <Style x:Key="K8sDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource App.Background.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Text.Primary}"/>
            <Setter Property="RowBackground" Value="{DynamicResource App.Background.Surface}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource App.Background.Elevated}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource App.Border.Divider}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource K8sColumnHeader}"/>
            <Setter Property="RowStyle" Value="{StaticResource K8sRow}"/>
            <Setter Property="CellStyle" Value="{StaticResource K8sCell}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Cluster Navigator -->
        <Border Grid.Column="0"
                Background="{DynamicResource App.Background.Surface}"
                BorderBrush="{DynamicResource App.Border.Divider}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cluster Toolbar -->
                <Border Grid.Row="0" Style="{StaticResource Toolbar}" CornerRadius="8,0,0,0">
                    <Grid>
                        <TextBlock Text="Clusters" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Foreground="{DynamicResource App.Text.Primary}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="AddClusterButton" Click="AddClusterButton_Click"
                                    ToolTip="Add Cluster"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="6" Margin="0,0,4,0">
                                <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                      Fill="{DynamicResource App.Text.Primary}" Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                            <Button x:Name="RefreshAllButton" Click="RefreshAllButton_Click"
                                    ToolTip="Refresh All"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="6">
                                <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                      Fill="{DynamicResource App.Text.Primary}" Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Cluster Tree -->
                <TreeView x:Name="ClusterTreeView" Grid.Row="1"
                          BorderThickness="0"
                          Background="Transparent"
                          Padding="8"
                          SelectedItemChanged="ClusterTreeView_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource K8sTreeViewItem}"/>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource App.Border.Divider}"/>

        <!-- RIGHT PANEL: Content Area -->
        <Grid Grid.Column="2" Background="{DynamicResource App.Background.Window}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="0" MinHeight="0"/>
            </Grid.RowDefinitions>

            <!-- Top: Resource Grid -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Resource Toolbar -->
                <Border Grid.Row="0" Style="{StaticResource Toolbar}" CornerRadius="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="ResourceTypeLabel" Grid.Column="0"
                                   Text="Select a cluster and resource type"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="4,0,12,0"
                                   Foreground="{DynamicResource App.Text.Primary}"/>

                        <ComboBox x:Name="NamespaceComboBox" Grid.Column="1"
                                  Width="180" Margin="0,0,12,0"
                                  materialDesign:HintAssist.Hint="Namespace"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  SelectionChanged="NamespaceComboBox_SelectionChanged"
                                  Visibility="Collapsed"/>

                        <TextBox x:Name="ResourceSearchBox" Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Filter..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Height="34" Margin="0,0,8,0"
                                 TextChanged="ResourceSearchBox_TextChanged"
                                 Visibility="Collapsed"/>

                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <Button x:Name="RefreshResourcesButton" Click="RefreshResourcesButton_Click"
                                    ToolTip="Refresh"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="6">
                                <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                      Fill="{DynamicResource App.Text.Primary}" Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Resource Content Area -->
                <Grid Grid.Row="1" Background="{DynamicResource App.Background.Surface}">
                    <!-- Pods DataGrid -->
                    <DataGrid x:Name="PodsDataGrid" Visibility="Collapsed"
                              Style="{StaticResource K8sDataGrid}"
                              MouseDoubleClick="PodsDataGrid_MouseDoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu Style="{StaticResource CompactContextMenu}">
                                <MenuItem Header="View Logs" Click="ViewLogsMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"
                                              Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="View Previous Logs" Click="ViewPreviousLogsMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M13,3A9,9 0 0,0 4,12H1L4.89,15.89L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,19.99 10.51,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3Z"
                                              Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Open Terminal" Click="OpenTerminalMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M20,19V7H4V19H20M20,3A2,2 0 0,1 22,5V19A2,2 0 0,1 20,21H4A2,2 0 0,1 2,19V5C2,3.89 2.9,3 4,3H20M13,17V15H18V17H13M9.58,13L5.57,9H8.4L11.7,12.3C12.09,12.69 12.09,13.33 11.7,13.72L8.42,17H5.59L9.58,13Z"
                                              Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Describe Pod" Click="DescribePodMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z"
                                              Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Port Forward..." Click="PortForwardMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M17,13H13V17H11V13H7V11H11V7H13V11H17V13Z"
                                              Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Copy Pod Name" Click="CopyPodNameMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"
                                              Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Delete Pod" Click="DeletePodMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                              Fill="#F44336" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Ready" Binding="{Binding Ready}" Width="60"/>
                            <DataGridTemplateColumn Header="Status" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" FontWeight="Medium"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Restarts" Binding="{Binding Restarts}" Width="70"/>
                            <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="60"/>
                            <DataGridTextColumn Header="Node" Binding="{Binding Node}" Width="150"/>
                            <DataGridTextColumn Header="IP" Binding="{Binding IP}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Deployments DataGrid -->
                    <DataGrid x:Name="DeploymentsDataGrid" Visibility="Collapsed"
                              Style="{StaticResource K8sDataGrid}">
                        <DataGrid.ContextMenu>
                            <ContextMenu Style="{StaticResource CompactContextMenu}">
                                <MenuItem Header="Scale..." Click="ScaleDeploymentMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M17,13H13V17H11V13H7V11H11V7H13V11H17V13Z"
                                              Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Restart" Click="RestartDeploymentMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                              Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Rollout Status" Click="RolloutStatusMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z"
                                              Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Rollout History" Click="RolloutHistoryMenuItem_Click" Style="{StaticResource CompactMenuItem}">
                                    <MenuItem.Icon>
                                        <Path Data="M13,3A9,9 0 0,0 4,12H1L4.89,15.89L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,19.99 10.51,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3Z"
                                              Fill="{DynamicResource App.Text.Secondary}" Width="12" Height="12" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Ready" Binding="{Binding ReadyDisplay}" Width="80"/>
                            <DataGridTextColumn Header="Up-to-Date" Binding="{Binding UpdatedReplicas}" Width="90"/>
                            <DataGridTextColumn Header="Available" Binding="{Binding AvailableReplicas}" Width="80"/>
                            <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="80"/>
                            <DataGridTextColumn Header="Strategy" Binding="{Binding Strategy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Events DataGrid -->
                    <DataGrid x:Name="EventsDataGrid" Visibility="Collapsed"
                              Style="{StaticResource K8sDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Type" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Type}" Foreground="{Binding TypeColor}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="120"/>
                            <DataGridTextColumn Header="Object" Binding="{Binding Object}" Width="150"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="50"/>
                            <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeenText}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Describe/Raw Text View -->
                    <TextBox x:Name="DescribeTextBox" Visibility="Collapsed"
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             BorderThickness="0"
                             Background="{DynamicResource App.Background.Surface}"
                             Foreground="{DynamicResource App.Text.Primary}"
                             CaretBrush="{DynamicResource App.Text.Primary}"
                             Padding="12"/>

                    <!-- Status Message -->
                    <TextBlock x:Name="StatusMessage"
                               Text="Select a cluster from the left panel to get started"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource App.Text.Secondary}"
                               FontSize="14"/>
                </Grid>
            </Grid>

            <!-- Bottom Splitter -->
            <GridSplitter x:Name="BottomSplitter" Grid.Row="1" Height="4"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Background="{DynamicResource App.Border.Divider}" Visibility="Collapsed"/>

            <!-- Bottom Panel: Logs / Terminal Tabs -->
            <Border x:Name="BottomPanel" Grid.Row="2" Visibility="Collapsed"
                    Background="{DynamicResource App.Background.Surface}"
                    BorderBrush="{DynamicResource App.Border.Divider}" BorderThickness="0,1,0,0">
                <Grid>
                    <TabControl x:Name="BottomTabControl" BorderThickness="0"
                                Background="Transparent" Padding="0"/>
                    <Button x:Name="CloseBottomPanelButton" Click="CloseBottomPanelButton_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Style="{StaticResource SecondaryButton}"
                            Padding="4" Margin="0,2,4,0"
                            ToolTip="Close Panel">
                        <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                              Fill="{DynamicResource App.Text.Secondary}" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
