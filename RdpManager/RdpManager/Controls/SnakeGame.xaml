<UserControl x:Class="RdpManager.Controls.SnakeGame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             FocusVisualStyle="{x:Null}"
             PreviewKeyDown="UserControl_PreviewKeyDown"
             MouseDown="UserControl_MouseDown">

    <Grid Background="{DynamicResource App.Background.Window}" Focusable="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Score Header -->
        <Border Grid.Row="0" Background="{DynamicResource App.Background.Elevated}"
                Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🐍 SNAKE" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource App.Text.Primary}"/>
                    <TextBlock Text="Use arrow keys to move • Eat the food • Don't hit walls or yourself!"
                               FontSize="12" Foreground="{DynamicResource App.Text.Secondary}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBlock Text="SCORE" FontSize="11" FontWeight="Medium"
                               Foreground="{DynamicResource App.Text.Secondary}"/>
                    <TextBlock x:Name="ScoreText" Text="0" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource App.Primary}"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Exit" Padding="16,8"
                        Background="Transparent"
                        BorderBrush="{DynamicResource App.Border.Outline}"
                        BorderThickness="1"
                        Foreground="{DynamicResource App.Text.Primary}"
                        FontWeight="Medium"
                        Cursor="Hand"
                        Click="ExitButton_Click"
                        VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource App.Hover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Game Area -->
        <Border Grid.Row="1" Background="{DynamicResource App.Background.Surface}"
                BorderBrush="{DynamicResource App.Border.Divider}"
                BorderThickness="2"
                CornerRadius="8"
                Margin="20">
            <Viewbox Stretch="Uniform">
                <Canvas x:Name="GameCanvas" Width="400" Height="400" Background="#0A1929" ClipToBounds="True"/>
            </Viewbox>
        </Border>

        <!-- Game Over Overlay -->
        <Border x:Name="GameOverPanel" Grid.Row="1" Background="#CC000000"
                Visibility="Collapsed">
            <Border Background="{DynamicResource App.Background.Surface}"
                    BorderBrush="{DynamicResource App.Primary}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="300">
                <StackPanel>
                    <TextBlock Text="GAME OVER" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource App.Text.Primary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="FinalScoreText" Text="Score: 0" FontSize="20"
                               Foreground="{DynamicResource App.Text.Secondary}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,24"/>
                    <Button Content="Play Again" Padding="20,10"
                            Background="{DynamicResource App.Primary}"
                            Foreground="{DynamicResource App.Primary.Foreground}"
                            BorderThickness="0"
                            FontSize="16"
                            FontWeight="Medium"
                            Cursor="Hand"
                            Click="PlayAgainButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
